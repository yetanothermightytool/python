# Veeam Backup & Replication API
VBR_URL=https://<vbr-server>:9419
VBR_API_VERSION=1.2-rev1
VBR_USERNAME=Administrator

# Fernet-encrypted password (generate with encrypt-password.py)
VBR_PASSWORD=<encrypted-password>

# Path to the Fernet key file (e.g. /root/.vbr.key)
VBR_KEY_FILE=/root/.vbr.key

# Directory on the host where scan results are written
RESULTS_DIR=/tmp/output
