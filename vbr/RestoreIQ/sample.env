# Copy this file to .env and fill in your values.
# The dashboard script loads .env automatically if python-dotenv is installed.

# ── Veeam B&R REST API ────────────────────────────────────────────────────────
VEEAM_URL=https://veeam.corp.local:9419
VEEAM_USERNAME=administrator
VEEAM_PASSWORD=your-password-here

# Set to false if Veeam uses a self-signed certificate (or use --no-ssl-verify)
# VEEAM_VERIFY_SSL=true

# Override API version header sent with every request (default: 1.3-rev1)
VEEAM_API_VERSION=1.3-rev1
