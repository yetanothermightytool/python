# Copy to .env and fill in values — never commit .env

# ── Veeam ──────────────────────────────────────────────────────────────────
VEEAM_URL=https://vbr-server:9419
VEEAM_USERNAME=<username>
VEEAM_PASSWORD=changeme
VEEAM_VERIFY_SSL=true

# ── Recovery policy ────────────────────────────────────────────────────────
CONFIRMATION_TTL_MINUTES=30
RESTORE_CONFIDENCE_THRESHOLD=70
# JSON array or comma-separated list, e.g. repo-primary,offsite-vault
PREFERRED_REPOSITORIES=

# ── New Relic (EU) ─────────────────────────────────────────────────────────
NR_ACCOUNT_ID=your-account-id
NR_LICENSE_KEY=your-license-key
# EU endpoint is the default — remove this line if you want to change region
NR_EVENTS_ENDPOINT=https://insights-collector.eu01.nr-data.net/v1/accounts/{account_id}/events

# Required unless ALLOW_UNAUTHENTICATED_DEV=true
NR_WEBHOOK_SECRET=change-me-webhook-secret

# Required unless ALLOW_UNAUTHENTICATED_DEV=true
# Passed as X-API-Key header
AGENT_API_KEY=change-me-agent-api-key

# Local development only. Do not enable in production.
ALLOW_UNAUTHENTICATED_DEV=false

# ── Service ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
