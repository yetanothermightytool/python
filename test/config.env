VEEAM_HOST=https://your-veeam-server:9419
VEEAM_USER=your-username
VEEAM_PASS=your-password
# Optional: set to false to skip SSL verification (self-signed certs)
VEEAM_SSL_VERIFY=false
# Absolute path on the Veeam server where audit log files will be copied
VEEAM_OUTPUT_PATH=/home/administrator/entraid/logs

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your-neo4j-password

# SMB share where restored logs are located (Windows server)
SMB_HOST=windows-server-ip-or-hostname
SMB_SHARE=entraid-logs
SMB_USER=administrator
SMB_PASS=your-windows-password
SMB_DOMAIN=
# Sub-path within the share (leave empty if logs are at share root)
SMB_PATH=
